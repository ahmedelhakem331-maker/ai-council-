# =============================================================================
# AI COUNCIL - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values
# DO NOT COMMIT .env.local to version control

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Council
NEXT_PUBLIC_LANG=en

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# OpenAI API Configuration
OPENAI_API_KEY=sk_test_xxxxxxxxxxxxx
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FALLBACK=gpt-3.5-turbo
OPENAI_TIMEOUT_SECONDS=5
OPENAI_MAX_TOKENS=2000

# Groq API Configuration (Fallback LLM Provider)
GROQ_API_KEY=gsk_xxxxxxxxxxxxx
GROQ_MODEL=llama-3-70b-versatile

# DALL-E 3 Configuration
DALLE3_MODEL=dall-e-3
DALLE3_SIZE=1024x1024
DALLE3_QUALITY=standard

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Database Configuration
DB_USER=ai_council_user
DB_PASSWORD=your_secure_password_here
DB_NAME=ai_council_db
DATABASE_URL=postgresql://ai_council_user:your_secure_password_here@db:5432/ai_council_db

# Optional: Neon.tech PostgreSQL URL (for production)
# DATABASE_URL=postgresql://user:password@xxx.neon.tech/dbname?sslmode=require

# Prisma Configuration
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_STRUCTURED_LOGGING=true
ENABLE_TRACE_ID_CORRELATION=true

# =============================================================================
# QUALITY ASSURANCE
# =============================================================================
ENABLE_LLM_JUDGE=true
QUALITY_GATE_THRESHOLD=3.0
QUALITY_GATE_TIMEOUT_SECONDS=10

# =============================================================================
# DEPLOYMENT
# =============================================================================
NODE_ENV=development
# NODE_ENV=production (for production builds)

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_WEBSOCKET_ORIGINS=ws://localhost:8000

# =============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# =============================================================================
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# DATADOG_API_KEY=xxxxx
# ENABLE_ANALYTICS=true

# =============================================================================
# OPTIONAL: ADMIN DASHBOARD
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
ENABLE_ADMIN_DASHBOARD=true
